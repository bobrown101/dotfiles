#!/usr/bin/env node

const commands = require("./todo-lib/commands");
const { printError, printHelp } = require("./todo-lib/view");

function parseArgs(argv) {
  const args = [];
  const flags = {};
  let i = 0;
  while (i < argv.length) {
    if (argv[i].startsWith("--")) {
      const key = argv[i].slice(2);
      if (i + 1 < argv.length && !argv[i + 1].startsWith("--")) {
        flags[key] = argv[++i];
      } else {
        flags[key] = true;
      }
    } else {
      args.push(argv[i]);
    }
    i++;
  }
  return { args, flags };
}

async function completions(argv) {
  const api = require("./todo-lib/api");
  const subcommand = argv[0];

  const SUBCOMMANDS = [
    "list\tList tasks",
    "add\tCreate a task",
    "done\tComplete a task",
    "delete\tDelete a task",
    "edit\tUpdate a task",
    "projects\tList projects",
    "help\tShow help",
  ];

  if (!subcommand) {
    SUBCOMMANDS.forEach((s) => console.log(s));
    return;
  }

  if (subcommand === "done" || subcommand === "delete" || subcommand === "edit") {
    try {
      const tasks = await api.listTasksQuick();
      for (const t of tasks) {
        const label = t.content.length > 40 ? t.content.slice(0, 40) + "..." : t.content;
        console.log(`${t.id}\t${label}`);
      }
    } catch {}
    return;
  }

  const prev = argv[argv.length - 1];
  if (prev === "--project") {
    try {
      const projects = await api.listProjectsQuick();
      for (const p of projects) console.log(p.name);
    } catch {}
    return;
  }

  if (subcommand === "list" || subcommand === "add") {
    console.log("--project");
    console.log("--priority");
    console.log("--due");
    if (subcommand === "add") {
      console.log("--description");
    }
    if (subcommand === "list") {
      console.log("--filter");
    }
  }
}

async function main() {
  const argv = process.argv.slice(2);

  if (argv[0] === "--completions") {
    await completions(argv.slice(1));
    return;
  }

  const command = argv[0] || "list";
  const rest = argv.slice(command === argv[0] ? 1 : 0);
  const { args, flags } = parseArgs(rest);

  try {
    switch (command) {
      case "list":
        await commands.list(flags);
        break;
      case "add":
        flags.content = args.length ? args.join(" ") : flags.content;
        await commands.add(flags);
        break;
      case "done":
        await commands.done(args);
        break;
      case "delete":
        await commands.del(args);
        break;
      case "edit":
        await commands.edit(args, flags);
        break;
      case "projects":
        await commands.projects();
        break;
      case "help":
      case "-h":
      case "--help":
        printHelp();
        break;
      default:
        printError(`Unknown command: ${command}`);
        printHelp();
        process.exit(1);
    }
  } catch (err) {
    printError(err.message);
    process.exit(1);
  }
}

main();
