#!/usr/bin/env node

const path = require("path");
const LIB = path.join(__dirname, "..", "lib", "ws");
const commands = require(path.join(LIB, "commands"));

const args = process.argv.slice(2);
const command = args[0];
const rest = args.slice(1);

const dispatch = {
  up: commands.up,
  rm: commands.rm,
  down: commands.down,
  nuke: commands.nuke,
  ls: commands.ls,
  attach: commands.attach,
  info: commands.info,
  help: commands.help,
  "--completions": commands.completions,
};

if (!command) {
  commands.help();
  process.exit(1);
}

const handler = dispatch[command];
if (!handler) {
  console.error(`Unknown command: ${command}`);
  commands.help();
  process.exit(1);
}

handler(rest);
